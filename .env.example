# Database (Neon)
# Runtime connection: the POOLED host (-pooler), sslmode=require. This is the
# only DB URL set in the Vercel runtime. See ADR-0002 (docs/adr/0002-production-deploy.md).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.neon.tech/strix?sslmode=require"
# Neon DIRECT (non-pooled) host. Used ONLY for `pnpm db:migrate` (run manually by
# the owner) — NOT set in the Vercel runtime. A build must never mutate the schema.
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/strix?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Endpoint-specific signing secret from Clerk's webhook dashboard.
# Verified against svix-id / svix-timestamp / svix-signature headers in
# src/app/api/webhooks/clerk/route.ts.
CLERK_WEBHOOK_SECRET=""
# Embedded auth routes (ADR-0002 decision 4): keep email/password sign-in on
# origin. The middleware (src/proxy.ts) public-lists /sign-in and /sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Anthropic (Phase 1+)
ANTHROPIC_API_KEY=""

# Replan banner gate — Phase 2 ships this ON: exactly "true" surfaces the
# structural-edit replan banner on goal detail; absent/empty/false = no
# banner anywhere (the Phase 1 posture).
NEXT_PUBLIC_REPLAN_ENABLED=true

# PostHog
POSTHOG_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Inngest
# Local dev: set INNGEST_DEV=1 to put the SDK in dev mode (signature
# validation bypassed; the Inngest Dev Server at localhost:8288 handles
# things). Leave INNGEST_SIGNING_KEY / INNGEST_EVENT_KEY empty in dev.
# Preview + Production: INNGEST_DEV MUST be unset/absent in EVERY Vercel scope —
# if truthy, /api/inngest skips signature verification and the cron triggers
# become world-callable. On Vercel the keys below are set by the official
# Inngest Vercel integration (auto-synced on deploy), not entered by hand.
# See ADR-0002 (docs/adr/0002-production-deploy.md).
INNGEST_DEV=1
INNGEST_SIGNING_KEY=""
# Set by the Inngest Vercel integration on preview/prod; only filled by hand for
# local non-dev testing (from https://app.inngest.com → Manage → Event Keys).
INNGEST_EVENT_KEY=""

# STRIX_BUILD_ID is NOT set here and NOT a Vercel env var — it is build-injected
# by `serwist build` from .next/BUILD_ID (serwist.config.mjs) so it reaches the
# service-worker bundle. Do NOT set it in Vercel.

# Stripe (Phase 3)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (Phase 4)
RESEND_API_KEY=""

# Database (Neon)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/strix?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Endpoint-specific signing secret from Clerk's webhook dashboard.
# Verified against svix-id / svix-timestamp / svix-signature headers in
# src/app/api/webhooks/clerk/route.ts.
CLERK_WEBHOOK_SECRET=""

# Anthropic (Phase 1+)
ANTHROPIC_API_KEY=""

# Replan banner gate — Phase 2 ships this ON: exactly "true" surfaces the
# structural-edit replan banner on goal detail; absent/empty/false = no
# banner anywhere (the Phase 1 posture).
NEXT_PUBLIC_REPLAN_ENABLED=true

# PostHog
POSTHOG_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Inngest
# Local dev: set INNGEST_DEV=1 to put the SDK in dev mode (signature
# validation bypassed; the Inngest Dev Server at localhost:8288 handles
# things). Leave INNGEST_SIGNING_KEY / INNGEST_EVENT_KEY empty in dev.
# Production: unset INNGEST_DEV and fill both keys from
# https://app.inngest.com → Manage → Signing Key + Event Keys.
INNGEST_DEV=1
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# Stripe (Phase 3)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (Phase 4)
RESEND_API_KEY=""

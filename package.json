{
  "name": "strix",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-MIT",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "NODE_ENV=development serwist build serwist.config.mjs && next dev",
    "build": "next build && serwist build serwist.config.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "ci:check-unscoped": "node scripts/check-unscoped-db.mjs",
    "ci:check-doc-parity": "node scripts/check-doc-parity.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "verify:phase-0": "node scripts/verify-phase.mjs 0",
    "verify:ui": "playwright test",
    "verify:ui:update": "playwright test --update-snapshots",
    "verify:db-schema": "tsx --env-file=.env.local scripts/verify-schema.ts",
    "smoke:scoped-db": "tsx --env-file=.env.local scripts/smoke-scoped-db.ts",
    "smoke:posthog": "tsx --env-file=.env.local scripts/smoke-posthog.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.112.3",
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^6.16.0",
    "@neondatabase/serverless": "^0.10.4",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@serwist/next": "^9.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "inngest": "^3.27.5",
    "lucide-react": "^0.469.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.404.1",
    "posthog-node": "^4.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "svix": "^1.98.0",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@serwist/cli": "^9.5.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "serwist": "^9.5.11",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "next>postcss": ">=8.5.10",
      "esbuild": ">=0.28.1",
      "form-data": ">=4.0.6"
    }
  }
}

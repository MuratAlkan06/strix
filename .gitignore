# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright (verify:ui) — keep snapshot baselines (e2e/**-snapshots/), drop run artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
# playwright-mcp browser-review artifacts (recurs every design review)
/.playwright-mcp/

# next.js
/.next/
/out/

# service worker build artifact (emitted by `serwist build` — serwist.config.mjs)
/public/sw.js
/public/sw.js.map

# production
/build

# misc
.DS_Store
*.pem
.pnpm-store/

# local tool settings/scratch
.claude/

# internal business notes — not for the public repo
docs/private/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
